{
  "compilerOptions": {
    "target": "es2021",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": false,
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "stripInternal": true,
    "paths": {
      "*": ["./assets/js/*", "./assets/js/phoenix_live_view/*"]
    },
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": ".",
    "outDir": "./assets/js/types"
  },
  "include": [
    "./assets/js/phoenix_live_view/*.js",
    "./assets/js/phoenix_live_view/*.ts"
  ]
}
